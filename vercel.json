{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/v1/(.*)", "dest": "/api/v1/$1" },
    { "src": "/health", "dest": "/api/health" }
  ]
}
