{
  "policies": [
    {
      "name": "api-key-auth",
      "policyType": "api-key-inbound",
      "handler": {
        "export": "ApiKeyInboundPolicy",
        "module": "$import(@zuplo/runtime)"
      }
    },
    {
      "name": "inject-zuplo-secret",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "default",
        "module": "$import(./modules/inject-secret)"
      }
    },
    {
      "name": "dynamic-rate-limit",
      "policyType": "rate-limit-v1",
      "handler": {
        "export": "RateLimitInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "rateLimitBy": "function",
          "requestsPerMinute": 5,
          "function": {
            "export": "getRateLimit",
            "module": "$import(./modules/tiered-limits)"
          }
        }
      }
    },
    {
      "name": "dynamic-quota",
      "policyType": "quota-v1",
      "handler": {
        "export": "QuotaInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "rateLimitBy": "function",
          "limit": 250,
          "window": "30d",
          "function": {
            "export": "getQuota",
            "module": "$import(./modules/tiered-limits)"
          }
        }
      }
    }
  ]
}
