{
  "policies": [
    {
      "name": "supabase-auth",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "default",
        "module": "$import(./modules/supabase-auth)"
      }
    },
    {
      "name": "inject-zuplo-secret",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "default",
        "module": "$import(./modules/inject-secret)"
      }
    },
    {
      "name": "dynamic-rate-limit",
      "policyType": "rate-limit-inbound",
      "handler": {
        "export": "RateLimitInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "rateLimitBy": "function",
          "requestsAllowed": 5,
          "timeWindowMinutes": 1,
          "identifier": {
            "export": "getRateLimit",
            "module": "$import(./modules/tiered-limits)"
          }
        }
      }
    },
    {
      "name": "dynamic-quota",
      "policyType": "quota-inbound",
      "handler": {
        "export": "QuotaInboundPolicy",
        "module": "$import(@zuplo/runtime)",
        "options": {
          "quotaBy": "function",
          "period": "monthly",
          "identifier": {
            "export": "getQuota",
            "module": "$import(./modules/tiered-limits)"
          }
        }
      }
    },
    {
      "name": "cors",
      "policyType": "custom-code-inbound",
      "handler": {
        "export": "default",
        "module": "$import(./modules/cors-handler)"
      }
    }
  ]
}
