{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "RenderKit Screenshot API",
    "description": "High-performance infrastructure for web screenshots, PDF generation, and OG images."
  },
  "paths": {
    "/v1/screenshot/capture": {
      "post": {
        "summary": "Capture Screenshot",
        "operationId": "captureScreenshot",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors",
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/pdf": {
      "post": {
        "summary": "Generate PDF",
        "operationId": "generatePdf",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors",
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/og": {
      "post": {
        "summary": "Generate OG Image",
        "operationId": "generateOgImage",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors",
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/webhooks/dodo": {
      "post": {
        "summary": "Dodo Payments Webhook",
        "description": "Receives subscription events from Dodo Payments and syncs users to Zuplo consumer groups for tiered access.",
        "operationId": "dodoWebhook",
        "x-zuplo-route": {
          "handler": {
            "export": "default",
            "module": "$import(./modules/dodo-sync)"
          },
          "policies": {
            "inbound": [
              "cors"
            ]
          }
        },
        "responses": {
          "200": { "description": "Webhook processed successfully" },
          "400": { "description": "Invalid payload" },
          "401": { "description": "Invalid signature" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "API Health",
        "operationId": "apiHealth",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  }
}
