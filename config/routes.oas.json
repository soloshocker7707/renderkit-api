{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "RenderKit Screenshot API",
    "description": "High-performance infrastructure for web screenshots, PDF generation, and OG images."
  },
  "paths": {
    "/v1/screenshot/capture": {
      "post": {
        "summary": "Capture Screenshot",
        "operationId": "captureScreenshot",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors",
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": { "type": "string", "example": "https://google.com" },
                  "clean": { "type": "boolean", "description": "Auto-strip cookie banners and popups", "default": false },
                  "wait": { "type": "string", "enum": ["networkidle0", "networkidle2", "smart"], "default": "networkidle2" },
                  "freezeAnimations": { "type": "boolean", "default": true },
                  "css": { "type": "string", "description": "Inject custom CSS before capture" },
                  "template": { "type": "string", "description": "Use a predefined HTML template" },
                  "data": { "type": "object", "description": "Dynamic data for templates" },
                  "width": { "type": "integer", "default": 1280 },
                  "height": { "type": "integer", "default": 800 },
                  "fullPage": { "type": "boolean", "default": false },
                  "debug": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/pdf": {
      "post": {
        "summary": "Generate PDF",
        "operationId": "generatePdf",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors",
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "url": { "type": "string" },
                  "template": { "type": "string" },
                  "data": { "type": "object" },
                  "format": { "type": "string", "enum": ["A4", "Letter", "Legal"], "default": "A4" },
                  "landscape": { "type": "boolean", "default": false },
                  "clean": { "type": "boolean", "default": false }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/og": {
      "post": {
        "summary": "Generate OG Image",
        "operationId": "generateOgImage",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors",
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string" },
                  "description": { "type": "string" },
                  "theme": { "type": "string", "enum": ["dark", "light", "green"], "default": "dark" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "API Health",
        "operationId": "apiHealth",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "cors"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Landing Page",
        "operationId": "getLandingPage",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app"
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/webhooks/dodo": {
      "post": {
        "summary": "Dodo Payment Webhook Sync",
        "operationId": "dodoWebhookSync",
        "x-zuplo-route": {
          "handler": {
            "export": "default",
            "module": "$import(./modules/dodo-sync)"
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/{path+}": {
      "get": {
        "summary": "Static Assets",
        "operationId": "getStaticAssets",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://renderkit-api.vercel.app/{path}"
            }
          },
          "policies": {
            "inbound": [
              "cors"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  }
}
