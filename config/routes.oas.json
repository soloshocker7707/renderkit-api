{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "Pint Screenshot API",
    "description": "High-performance API for web screenshots, PDF generation, and OG images."
  },
  "paths": {
    "/v1/screenshot/capture": {
      "post": {
        "summary": "Capture Screenshot",
        "operationId": "captureScreenshot",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/pdf": {
      "post": {
        "summary": "Generate PDF",
        "operationId": "generatePdf",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/v1/screenshot/og": {
      "post": {
        "summary": "Generate OG Image",
        "operationId": "generateOgImage",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          },
          "policies": {
            "inbound": [
              "supabase-auth",
              "dynamic-quota",
              "dynamic-rate-limit",
              "inject-zuplo-secret"
            ]
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "API Health",
        "operationId": "apiHealth",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/api"
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Landing Page",
        "operationId": "getLandingPage",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app"
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/webhooks/dodo": {
      "post": {
        "summary": "Dodo Payment Webhook Sync",
        "operationId": "dodoWebhookSync",
        "x-zuplo-route": {
          "handler": {
            "export": "default",
            "module": "$import(./modules/dodo-sync)"
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/{path+}": {
      "get": {
        "summary": "Static Assets",
        "operationId": "getStaticAssets",
        "x-zuplo-route": {
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://pint-api-delta.vercel.app/{path}"
            }
          }
        },
        "responses": {
          "200": { "description": "OK" }
        }
      }
    }
  }
}
