# ===========================================
# RenderKit API - Environment Variables
# ===========================================
#
# Copy this file to .env and fill in your values
# cp env.example .env

# --- Zuplo Gateway Configuration ---
# Get these from Zuplo Portal (Settings → API Keys)
ZUPLO_API_KEY=zpka_your_zuplo_management_api_key
ZUPLO_GATEWAY_ID=your_zuplo_gateway_id
ZUPLO_ENVIRONMENT=production

# --- Dodo Payments Configuration ---
# Get these from Dodo Payments Dashboard (Settings → Webhooks)
DODO_API_KEY=dodo_your_dodo_api_key
DODO_WEBHOOK_SECRET=whsec_your_dodo_webhook_signing_secret

# --- Supabase Database ---
# Required for production auth (if not using mock keys)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Internal Secret (injected to upstream) ---
# Must match what your Vercel API expects
SECRET_ZUPLO=your_shared_secret_for_vercel_verification

# --- Optional: Rate Limiting & Quota ---
# These can be configured in Zuplo Portal instead
RATE_LIMIT_ENABLED=true
QUOTA_ENABLED=true