{
	"info": {
		"_postman_id": "c0b76168-8129-4046-8880-82c97f00184b",
		"name": "PintAPI - SaaS Screenshot Engine",
		"description": "High-performance API for screenshots, PDFs, and OG images with Smart Wait and Anti-Bot stealth capabilities.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Screenshots",
			"item": [
				{
					"name": "Capture Screenshot",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "x-api-key",
								"value": "{{apiKey}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"url\": \"https://google.com\",\n  \"width\": 1280,\n  \"height\": 800,\n  \"fullPage\": false,\n  \"wait\": \"auto\",\n  \"stealth\": true,\n  \"format\": \"png\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/v1/screenshot/capture",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"v1",
								"screenshot",
								"capture"
							]
						},
						"description": "Capture a high-fidelity screenshot. Use `wait: \"auto\"` for the Smart Wait Engine (stability detection)."
					},
					"response": []
				}
			]
		},
		{
			"name": "PDF Generation",
			"item": [
